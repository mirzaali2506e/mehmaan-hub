# Mehmaan Hub Environment Configuration
# Copy this file to .env and fill in your values

# Database
DB_HOST=localhost
DB_NAME=mehmaan_hub
DB_USER=root
DB_PASS=

# Site
SITE_URL=http://localhost/mhman-hb/php-project
SITE_NAME=Mehmaan Hub

# SMTP (for password reset OTP emails)
# For Gmail: use smtp.gmail.com, port 587, and an App Password (not your account password)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
